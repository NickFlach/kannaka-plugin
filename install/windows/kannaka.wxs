<?xml version="1.0" encoding="UTF-8"?>
<!-- Per-user MSI (no admin) that lays down install.ps1 and runs it post-install
     in the user's context. Wraps install/install.ps1 (the shared engine). -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Kannaka Setup"
           Manufacturer="Nick Flach"
           Version="1.3.0"
           UpgradeCode="7E9C2A14-3B6D-4F8E-9A21-5C0D8F1B2E33"
           Scope="perUser"
           Compressed="yes">
    <MajorUpgrade DowngradeErrorMessage="A newer version of Kannaka is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="Kannaka">
        <Component Id="InstallScript" Guid="A1B2C3D4-1111-2222-3333-444455556666">
          <File Id="install_ps1" Source="install\install.ps1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="Kannaka" Level="1">
      <ComponentRef Id="InstallScript" />
    </Feature>

    <!-- Run the engine as the installing user after files land. -->
    <CustomAction Id="RunKannakaInstall"
                  Directory="INSTALLFOLDER"
                  ExeCommand="powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]install.ps1&quot;"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />
    <InstallExecuteSequence>
      <Custom Action="RunKannakaInstall" After="InstallFiles" Condition="NOT Installed" />
    </InstallExecuteSequence>
  </Package>
</Wix>
